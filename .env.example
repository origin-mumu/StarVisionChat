# StarVisionChat 环境变量配置

# 调试模式
DEBUG=true

# 服务器配置
HOST=0.0.0.0
PORT=8000

# MiMo API 配置（TokenPlan 会员）
MIMO_API_KEY=your-mimo-api-key
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1

# 对话模型（内置多模态，支持文本/图像/音频/视频输入）
CHAT_MODEL=mimo-v2.5
CHAT_MAX_TOKENS=1024

# 语音识别模型 (ASR)
ASR_MODEL=mimo-v2.5-asr

# 语音合成模型 (TTS)
TTS_MODEL=mimo-v2.5-tts
TTS_VOICE=mimo_default

# 帧采样配置
FRAME_INTERVAL=2.0
FRAME_QUALITY=60
FRAME_MAX_WIDTH=640

# 对话配置
MAX_HISTORY_TURNS=10

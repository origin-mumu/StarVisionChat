# StarVisionChat 环境变量配置

# 调试模式
DEBUG=true

# 服务器配置
HOST=0.0.0.0
PORT=8000

# OpenAI API 配置
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# 视觉模型配置
VISION_MODEL=gpt-4o-mini
VISION_MODEL_STRONG=gpt-4o
VISION_MAX_TOKENS=300

# 对话模型配置
CHAT_MODEL=gpt-4o-mini
CHAT_MODEL_STRONG=gpt-4o
CHAT_MAX_TOKENS=500

# STT 配置 (local / cloud)
STT_MODE=local
WHISPER_MODEL=base

# TTS 配置 (edge / openai)
TTS_MODE=edge
TTS_VOICE=zh-CN-XiaoxiaoNeural

# 帧采样配置
FRAME_INTERVAL=2.0
FRAME_QUALITY=60
FRAME_MAX_WIDTH=640

# 对话配置
MAX_HISTORY_TURNS=10
